# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs (voice generation)
ELEVENLABS_API_KEY=...

# Google (YouTube upload)
# Provide as a JSON string of OAuth2 credentials
YOUTUBE_CREDENTIALS_JSON=...

# Meta / Instagram
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...

# AWS S3 (video hosting)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=ap-south-1
S3_BUCKET_NAME=meepanthulu

# Email approval notifications (optional)
APPROVAL_EMAIL_FROM=
APPROVAL_EMAIL_TO=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
